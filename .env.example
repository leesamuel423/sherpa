LLM_PROVIDER=groq
GROQ_API_KEY=gsk_...
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=
MAX_ATTEMPTS=3
WALL_CLOCK_LIMIT_SECONDS=60
GROUNDING_THRESHOLD=75.0
ENABLE_LLM_CONSISTENCY_CHECK=false
KEYWORD_STRATEGY=llm
LOG_LEVEL=INFO
API_TIMEOUT_SECONDS=5

ENABLED_SOURCES=["wikipedia","arxiv","hackernews"]
SOURCE_WIKIPEDIA_MAX_SENTENCES=10
SOURCE_ARXIV_MAX_RESULTS=3
SOURCE_HACKERNEWS_MAX_STORIES=5
